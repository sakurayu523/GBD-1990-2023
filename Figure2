gbdall <- gbd_all %>%
  left_join(gbd_pop %>% select(location_id, year, age_id, sex_id, val), 
            by = c("location_id", "year", "age_id", "sex_id"),
            suffix = c("_rate", "_pop")) %>%
  rename(population = val_pop) 

library(dplyr)
colnames(gbdall)
  # 1. Filter data
  plot_data_final <- gbdall %>%
  filter(
    metric_name == "Rate",
    sex_name == "Female",
    cause_name == "Cardiovascular diseases",
    age_id %in% c(14, 15) # 45-49 and 50-54
  ) %>%
  # 2. Convert data types
  mutate(
    val_rate = as.numeric(val_rate),
    population = as.numeric(population)
  ) %>%
  # 3. Calculate weighted average for 45-54 age group
  group_by(location_name, year, measure_name) %>%
  summarise(
    val = sum(val_rate * population, na.rm = TRUE) / sum(population, na.rm = TRUE),
    .groups = 'drop'
  ) %>%
  # 4. Rename for plotting
  rename(
    location_label = location_name,
    measure = measure_name
  ) %>%
  # 5. Factor levels for plotting order
  mutate(location_label = factor(location_label, 
                                 levels = c("Global", "East Asia", "China", "Japan", "Republic of Korea", 
                                            "Democratic People's Republic of Korea", "Mongolia", "Taiwan"))) %>%
  # 6. Filter measures
  filter(measure %in% c("Deaths", "Incidence", "Prevalence"))

library(ggplot2)
library(patchwork)

draw_lancet_block_enlarged <- function(target_measure, color_code, plot_title) {
  plot_data_final %>%
    filter(measure == target_measure) %>%
    ggplot(aes(x = year, y = val, color = location_label)) +
    geom_line(linewidth = 1) +
    geom_point(size = 0.5) +
    scale_color_brewer(palette = "Set1") + 
    theme_minimal() +
    labs(title = plot_title, x = "Year", y = "Rate") +
    theme(
      legend.position = "bottom",
      panel.grid.minor = element_blank(),
      text = element_text(family = "serif") # Lancet standard serif font
    )
}

