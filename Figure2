read_zip_to_df <- function(zip_file) {
  files_in_zip <- unzip(zip_file, list = TRUE)$Name
  csv_file <- files_in_zip[grep("\\.csv$", files_in_zip)]
  
  # 读取 csv，强制字符型以防止列类型冲突
  data <- read_csv(unz(zip_file, csv_file), col_types = cols(.default = "c"))
  return(data)
}

