library(dplyr)
library(readr)
library(purrr)
library(data.table)

# 1. Set data path
data_path <- "F:/yu/GBD/female/data"

# 2. Define function to unzip and read CSVs efficiently
read_gbd_zip <- function(zip_file) {
  tmp_dir <- tempfile("gbd_zip_")
  dir.create(tmp_dir)
  on.exit(unlink(tmp_dir, recursive = TRUE), add = TRUE)
  
  # List and identify csv files
  zip_list <- utils::unzip(zip_file, list = TRUE)
  csv_names <- zip_list$Name[grepl("\\.csv$", zip_list$Name, ignore.case = TRUE)]
  
  if (length(csv_names) == 0) return(data.table())
  
  # Unzip and read
  utils::unzip(zip_file, files = csv_names, exdir = tmp_dir)
  csv_paths <- list.files(tmp_dir, pattern = "\\.csv$", recursive = TRUE, full.names = TRUE)
  
  # Use fread for fast reading and combine
  out <- rbindlist(lapply(csv_paths, fread), fill = TRUE)
  out[, source_zip := basename(zip_file)]
  return(out)
}

# 3. Define function to read zips while excluding the specific population file
read_gbd_zips_filtered <- function(path) {
  all_zip_files <- list.files(path, pattern = "\\.zip$", full.names = TRUE)
  exclude_file <- "IHME-GBD_2023_DATA-4ee9b1e1-1.zip"
  
  target_zip_files <- all_zip_files[!grepl(exclude_file, basename(all_zip_files))]
  
  if (length(target_zip_files) == 0) {
    stop("No valid .zip files found.", call. = FALSE)
  }
  
  message("Processing the following archives:")
  cat(paste(basename(target_zip_files), collapse = "\n"), "\n")
  
  rbindlist(lapply(target_zip_files, read_gbd_zip), fill = TRUE)
}

# 4. Execute reading
gbd_all <- read_gbd_zips_filtered(data_path)

# 5. Load and join population data
pop_zip_path <- file.path(data_path, "IHME-GBD_2023_DATA-4ee9b1e1-1.zip")
tmp_dir_pop <- tempdir()
unzip(pop_zip_path, exdir = tmp_dir_pop)
pop_file <- list.files(tmp_dir_pop, pattern = "\\.csv$", full.names = TRUE)
gbd_pop <- read_csv(pop_file[1])

# Merge datasets
gbd_all_joined <- gbd_all %>%
  left_join(gbd_pop %>% select(location_id, year, age_id, sex_id, val), 
            by = c("location_id", "year", "age_id", "sex_id"),
            suffix = c("_rate", "_pop")) %>%
  rename(population = val_pop)

# 6. Data Aggregation using data.table
setDT(gbd_all_joined)

# Define grouping columns (excluding numeric values)
cols_to_group <- c("location_name", "year", "sex_id", "sex_name", 
                   "age_id", "age_name", "cause_id", "cause_name", 
                   "measure_id", "measure_name", "metric_id", "metric_name")

# Rename "Taiwan" to "China" and aggregate
gbd_all_joined[location_name == "Taiwan", location_name := "China"]

gbd_final <- gbd_all_joined[, .(
  val_rate = sum(val_rate, na.rm = TRUE),
  population = sum(population, na.rm = TRUE)
), by = cols_to_group]

# 7. Verify result
head(gbd_final)
# 1. Filter data
plot_data_final <- gbd_final %>%
  filter(
    metric_name == "Rate",
    sex_name == "Female",
    cause_name == "Cardiovascular diseases",
    age_id %in% c(14, 15) # 45-49 and 50-54
  ) %>%
  # 2. Convert data types
  mutate(
    val_rate = as.numeric(val_rate),
    population = as.numeric(population)
  ) %>%
  # 3. Calculate weighted average for 45-54 age group
  group_by(location_name, year, measure_name) %>%
  summarise(
    val = sum(val_rate * population, na.rm = TRUE) / sum(population, na.rm = TRUE),
    .groups = 'drop'
  ) %>%
  # 4. Rename for plotting
  rename(
    location_label = location_name,
    measure = measure_name
  ) %>%
  # 5. Factor levels for plotting order
  mutate(location_label = factor(location_label, 
                                 levels = c("Global", "East Asia", "China", "Japan", "Republic of Korea", 
                                            "Democratic People's Republic of Korea", "Mongolia", "Taiwan"))) %>%
  # 6. Filter measures
  filter(measure %in% c("Deaths", "Incidence", "Prevalence"))

library(ggplot2)
library(patchwork)

draw_lancet_block_enlarged <- function(target_measure, color_code, plot_title) {
  plot_data_final %>%
    filter(measure == target_measure) %>%
    ggplot(aes(x = year, y = val, color = location_label)) +
    geom_line(linewidth = 1) +
    geom_point(size = 0.5) +
    scale_color_brewer(palette = "Set1") + 
    theme_minimal() +
    labs(title = plot_title, x = "Year", y = "Rate") +
    theme(
      legend.position = "bottom",
      panel.grid.minor = element_blank(),
      text = element_text(family = "serif") # Lancet standard serif font
    )
}

# Generate plots for each measure
p1 <- draw_lancet_block_enlarged("Deaths", "#E41A1C", "Mortality Rate")
p2 <- draw_lancet_block_enlarged("Incidence", "#FF7F00", "Incidence Rate")
p3 <- draw_lancet_block_enlarged("Prevalence", "#377EB8", "Prevalence Rate")
plot
# Combine plots
figure2 <- (p1 + p2 + p3) + plot_layout(guides = 'collect') & theme(legend.position = 'bottom')
print(figure2)
ggsave("figure2.tiff", 
       plot = figure2, 
       width = 22, height = 12, units = "in", 
       dpi = 300, compression = "lzw")

ggsave("figure2.pdf", 
       plot = figure2, 
       width = 22, height = 12, 
       units = "in", 
       dpi = 300)
